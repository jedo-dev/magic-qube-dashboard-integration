HOST=127.0.0.1
PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/magic_qube_dashboard
LOG_LEVEL=info
API_KEY=change-me

ESP_BASE_URL=http://192.168.1.100
ESP_TIMEOUT_MS=4000
ESP_RETRY_COUNT=3
ESP_RETRY_DELAY_MS=1000
STOP_GIF_ON_RENDER=false

DEFAULT_POLL_INTERVAL_SEC=60
SCHEDULER_TICK_SEC=2
MAX_CONCURRENT_JOBS=2
IMAP_CONNECT_TIMEOUT_MS=10000

# Optional: passphrase for credentials encryption at rest.
# If empty, credentials are stored in encoded plain form.
CREDENTIALS_ENCRYPTION_KEY=
